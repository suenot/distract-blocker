---
const year = new Date().getFullYear();
---

<footer class="border-t border-border py-10 px-4 md:px-6 bg-background">
  <div class="container mx-auto max-w-6xl flex flex-col md:flex-row items-center justify-between gap-4">
    <p class="text-sm text-muted-foreground">
      © {year} Distract Blocker · MIT
    </p>
    <div class="flex items-center gap-6 text-sm text-muted-foreground">
      <a href="https://github.com/suenot/distract-blocker" class="hover:text-foreground transition-colors">GitHub</a>
      <a href="https://github.com/suenot/distract-blocker/issues" class="hover:text-foreground transition-colors">Issues</a>
      <span class="opacity-60">made by
        <a href="https://marketmaker.cc" target="_blank" rel="noopener" class="hover:text-foreground transition-colors underline underline-offset-2">marketmaker.cc</a>
      </span>
    </div>
  </div>
</footer>
